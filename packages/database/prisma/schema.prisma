datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BookingStatus {
  Draft
  PendingPolicyAgree
  PendingPayment
  Confirmed
  PendingConsent
  PendingKYC
  ReadyForCheckin
  InProgress
  Completed
  CancelledByUser
  CancelledByStudio
  NoShow
  Disputed
  
  // v2.2.1 追加分 (設計Doc-03,04,05準拠)
  DepositRequired
  RequireApproval
  InDesign
}

enum PaymentStatus {
  Pending
  Succeeded
  Failed
  Refunded
}

enum PaymentType {
  Full
  Deposit
  DesignDeposit
}

enum AccountType {
  EXPRESS
  STANDARD
  CUSTOM
}

enum RiskTier {
  LOW
  MEDIUM
  HIGH
}

enum KYCStatus {
  UNSUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum ReservationDecision {
  ALLOW
  REQUIRE_DEPOSIT
  REQUIRE_APPROVAL
  BLOCK
}

enum DesignStatus {
  REQUESTED
  DEPOSIT_REQUIRED
  IN_PROGRESS
  REVIEW_PENDING
  APPROVED
  DELIVERED
}

enum AssetVisibility {
  PRIVATE
  SHARED_PREVIEW
  SHARED_FINAL
}

model Booking {
  id               String        @id @default(uuid())
  userId           String
  studioId         String
  status           BookingStatus @default(Draft)
  
  scheduledAtUtc   DateTime?
  scheduledAtLocal DateTime?
  studioTz         String?
  policySnapshot   Json?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  payments         Payment[]

  // ----- v2.2.1 新規追加 (破壊を防ぐため全てOptionalで関連) -----
  artistId                    String?
  notes                       String?
  pricingSnapshotId           String?
  reservationPolicyDecisionId String?

  // 追加リレーション定義
  studio   Studio? @relation(fields: [studioId], references: [id])
  user     User?   @relation(fields: [userId], references: [id])
  artist   ArtistProfile? @relation(fields: [artistId], references: [id])
  pricingSnapshot PricingSnapshot? @relation(fields: [pricingSnapshotId], references: [id])
  reservationDecision ReservationPolicyDecision? @relation(fields: [reservationPolicyDecisionId], references: [id])
  designRequests DesignRequest[]
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String
  paymentIntentId String        @unique
  status          PaymentStatus @default(Pending)
  amount          Int
  currency        String
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking         Booking       @relation(fields: [bookingId], references: [id])

  // ----- v2.2.1 新規追加 -----
  paymentType PaymentType @default(Full)
  
  // リレーション定義 (DesignDepositからの参照用)
  designDeposits DesignDeposit[]
}

model WebhookEvent {
  id                   String    @id
  type                 String
  receivedAt           DateTime  @default(now())
  processingStartedAt  DateTime? // 排他制御用ロック
  lockExpiresAt        DateTime? // ロック有効期限（スタック奪取用）
  processedAt          DateTime? // 正常処理完了時間
  errorJson            Json?
  processingResultJson Json?
}

model AuditLog {
  id          String   @id @default(uuid())
  actorType   String
  actorId     String
  entityType  String
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  requestId   String
  createdAt   DateTime @default(now())
}

model ConsentDocument {
  id          String   @id @default(uuid())
  version     String
  locale      String
  hash        String
  isPublished Boolean  @default(false)

  @@unique([version, locale])
}

model KYCSubmission {
  id                String    @id @default(uuid())
  bookingId         String    @unique
  encryptedFilePath String
  birthDate         DateTime
  status            String
  reviewedBy        String?
  reviewedAt        DateTime?
}

// ========== 新規モデル（完全追加） ==========

// 1. テナント・ユーザー基盤
model Studio {
  id                   String      @id @default(uuid())
  name                 String
  slug                 String      @unique // tenant boundary
  accountType          AccountType @default(EXPRESS)
  payoutStrategyKey    String      @default("default_express")
  requiresDeposit      Boolean     @default(false)
  depositAmount        Int         @default(10000)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  bookings       Booking[]
  staffs         Staff[]
  artists        ArtistProfile[]
  portfolioWorks PortfolioWork[]
  subscription   Subscription?
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kycStatus     KYCStatus @default(UNSUBMITTED)

  bookings       Booking[]
  riskProfile    RiskProfile?
  riskEvents     RiskEvent[]
  designRequests DesignRequest[]
  accounts       Account[]
  sessions       Session[]
}

model Staff {
  id          String   @id @default(uuid())
  studioId    String
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio  Studio @relation(fields: [studioId], references: [id])
  artists ArtistProfile[]
  reservationDecisions ReservationPolicyDecision[] 
}

// 2. アーティスト基盤
model ArtistProfile {
  id                String   @id @default(uuid())
  studioId          String
  staffId           String?  // Staffアカウントと紐づく場合
  displayName       String
  bio               String?  @db.Text
  profileImageUrl   String?
  gender            String?
  yearsOfExperience Int?
  specialties       String[] // 得意ジャンルタグ等
  instagramHandle   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio         Studio  @relation(fields: [studioId], references: [id])
  staff          Staff?  @relation(fields: [staffId], references: [id])
  portfolioWorks PortfolioWork[]
  bookings       Booking[]
  designRequests DesignRequest[]

  @@index([studioId])
}

model PortfolioWork {
  id            String   @id @default(uuid())
  artistId      String
  studioId      String
  title         String?
  description   String?  @db.Text
  mediaUrls     String[] // URL配列
  tags          String[] // タグ
  styleCategory String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  artist ArtistProfile @relation(fields: [artistId], references: [id])
  studio Studio        @relation(fields: [studioId], references: [id])

  @@index([artistId])
  @@index([studioId])
}

// 3. 価格見積・Risk決定基盤
model PricingSnapshot {
  id            String   @id @default(uuid())
  amount        Int
  currency      String
  breakdownJson Json
  version       String
  createdAt     DateTime @default(now())

  bookings Booking[]
}

model ReservationPolicyDecision {
  id                  String              @id @default(uuid())
  decision            ReservationDecision
  riskTier            RiskTier
  ruleVersion         String
  reasonCode          String?
  decidedAt           DateTime            @default(now())
  decidedByActorType  String              @default("system")
  decidedByStaffId    String?

  decidedByStaff Staff? @relation(fields: [decidedByStaffId], references: [id])
  bookings       Booking[]
}

// 4. デザイン要求と保護
model DesignRequest {
  id        String       @id @default(uuid())
  bookingId String
  userId    String
  artistId  String
  status    DesignStatus @default(REQUESTED)
  briefJson Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  booking       Booking         @relation(fields: [bookingId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
  artist        ArtistProfile   @relation(fields: [artistId], references: [id])
  designAssets  DesignAsset[]
  designDeposits DesignDeposit[]
}

model DesignDeposit {
  id              String   @id @default(uuid())
  designRequestId String
  amount          Int
  currency        String
  paymentId       String?  // 決済正本への参照
  paymentIntentId String?  // 外部Stripe参照(補助)

  createdAt       DateTime @default(now())

  designRequest DesignRequest @relation(fields: [designRequestId], references: [id])
  payment       Payment?      @relation(fields: [paymentId], references: [id])

  @@index([paymentIntentId])
}

model DesignAsset {
  id              String          @id @default(uuid())
  designRequestId String
  visibility      AssetVisibility @default(PRIVATE)
  watermarkPolicy String          @default("none")
  viewLimit       Int             @default(5)
  contentHash     String
  fileUrl         String
  
  designRequest DesignRequest @relation(fields: [designRequestId], references: [id])
}

// 5. リスク管理・プラン基盤
model RiskProfile {
  id       String   @id @default(uuid())
  userId   String   @unique
  tier     RiskTier @default(LOW)
  score    Int      @default(100)
  
  user     User     @relation(fields: [userId], references: [id])
}

model RiskEvent {
  id        String   @id @default(uuid())
  userId    String
  eventType String
  occurredAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Subscription {
  id         String    @id @default(uuid())
  studioId   String    @unique // Tenant Studio Boundary
  status     String    @default("active")
  graceUntil DateTime?
  
  studio     Studio    @relation(fields: [studioId], references: [id])
}

// ========== NextAuth v5 (Auth.js) 認証テーブル ==========

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ========== Tattoo-Friendly Facilities ==========

enum FacilityType {
  ONSEN     // 温泉
  SENTO     // 銭湯
  GYM       // ジム・プール
  HOTEL     // ホテル・旅館
  BEACH     // 海水浴場
  OTHER
}

enum TattooAcceptanceLevel {
  ALLOWED           // 全身OK・制限なし
  COVERED_ONLY      // ラッシュガードやシール等で隠せばOK
  PARTIAL_ONLY      // ワンポイントなど一部のみOK
  BANNED            // 一切禁止（入館不可）
  UNKNOWN           // 不明・要確認
}

model Facility {
  id              String                @id @default(uuid())
  name            String                // 施設名
  slug            String                @unique // URL用
  type            FacilityType          // 施設カテゴリ
  acceptanceLevel TattooAcceptanceLevel @default(UNKNOWN)
  description     String?               @db.Text
  
  // 場所情報
  prefecture   String?      // 都道府県
  city         String?      // 市区町村
  address      String?      // 番地以降
  
  // タトゥー関連ポリシー
  tattooPolicy String?      @db.Text
  
  // 画像・リンク
  mediaUrls    String[]
  websiteUrl   String?
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reports      FacilityReport[]
}

// 報告ステータス
enum ReportStatus {
  PENDING    // 承認待ち
  APPROVED   // 承認済み（データ反映済み）
  REJECTED   // 却下
}

// ユーザーからのタレコミ報告
model FacilityReport {
  id                String                @id @default(uuid())
  facilityId        String                @map("facility_id") // 対象施設
  userId            String?               // 投稿者（ログインしている場合のみ）
  
  // ユーザーが報告したタトゥー受け入れレベル
  reportedLevel     TattooAcceptanceLevel
  
  // 根拠となる情報
  evidenceText      String?               @db.Text // 実際に断られた、シールで入れた等の体験談
  evidenceUrl       String?               // 公式サイトのURLや参考リンク
  
  status            ReportStatus          @default(PENDING)
  adminNote         String?               @db.Text // 管理者のメモ（却下理由など）
  
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  facility          Facility              @relation(fields: [facilityId], references: [id])
}

