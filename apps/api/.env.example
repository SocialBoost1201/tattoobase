# ===================================
# TattooBase API - 環境変数テンプレート
# ===================================

# ─── Server ───
NODE_ENV=production
PORT=3000
# Comma-separated allowed origins
CORS_ORIGIN=https://tattoobase.jp,https://studio.tattoobase.jp
APP_BASE_URL=https://api.tattoobase.jp

# ─── Database (PostgreSQL) ───
# Railway PostgreSQL plugin sets this automatically
DATABASE_URL="postgresql://USER:PASS@host:5432/tattoobase?schema=public"

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxx

# ─── Pay.jp ───
PAYJP_SECRET_KEY=sk_live_xxxxxxxx
PAYJP_PUBLIC_KEY=pk_live_xxxxxxxx
PAYJP_WEBHOOK_SECRET=whsec_xxxxxxxx

# ─── Square ───
SQUARE_ACCESS_TOKEN=xxxxxxxx
SQUARE_LOCATION_ID=xxxxxxxx
SQUARE_APPLICATION_ID=xxxxxxxx
SQUARE_WEBHOOK_SIGNATURE_KEY=xxxxxxxx
# SQUARE_ENVIRONMENT=production

# ─── Stera Pack (三井住友カード) ───
STERA_API_KEY=xxxxxxxx
STERA_TERMINAL_ID=xxxxxxxx

# ─── Auth (JWT) ───
JWT_SECRET=<32文字以上のランダム文字列>
NEXTAUTH_SECRET=<32文字以上のランダム文字列>

# ─── AWS S3 (ポートフォリオ画像・KYC書類等) ───
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-1
# AWS_S3_BUCKET=tattoobase-uploads
