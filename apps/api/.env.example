# ===================================
# TattooBase API - 環境変数テンプレート
# ===================================

# ─── Server ───
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ─── Database (PostgreSQL) ───
DATABASE_URL="postgresql://USER@localhost:5432/tattoobase_dev?schema=public"

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ─── AWS S3 (ポートフォリオ画像・KYC書類等) ───
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-1
# AWS_S3_BUCKET=tattoobase-uploads

# ─── Auth (JWT / API Key) ───
# API_SECRET_KEY=<32文字以上のランダム文字列>
