# ===================================================
# TattooBase - 本番デプロイ環境変数チェックリスト
# ===================================================
# デプロイ前にすべての変数が設定されていることを確認してください。
# 「必須」はサービス起動に不可欠、「推奨」は運用上強く推奨されるものです。

# ─── [必須] Database ───
# DATABASE_URL=postgresql://user:password@host:5432/tattoobase_prod?schema=public&sslmode=require

# ─── [必須] API Server (apps/api) ───
# NODE_ENV=production
# PORT=3000
# CORS_ORIGIN=https://app.tattoobase.jp,https://studio.tattoobase.jp,https://admin.tattoobase.jp
# STRIPE_SECRET_KEY=sk_live_xxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_live_xxxxxxxx

# ─── [必須] User PWA (apps/user-pwa) ───
# NEXTAUTH_URL=https://app.tattoobase.jp
# AUTH_SECRET=<32文字以上のランダム文字列>
# AUTH_RESEND_KEY=re_xxxxxxxx
# NEXT_PUBLIC_API_URL=https://api.tattoobase.jp
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxx

# ─── [必須] Studio Web (apps/studio-web) ───
# NEXT_PUBLIC_API_URL=https://api.tattoobase.jp

# ─── [必須] Admin Web (apps/admin-web) ───
# NEXT_PUBLIC_API_URL=https://api.tattoobase.jp

# ─── [推奨] AWS S3 ───
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-1
# AWS_S3_BUCKET=tattoobase-uploads-prod

# ─── [推奨] 監視・ログ ───
# SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx
